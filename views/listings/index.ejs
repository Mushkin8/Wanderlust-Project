<% layout("/layouts/boilerplate") %>  

<style>
  #filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter{
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.7;
    text-decoration: none;
    color: inherit;
  }

  .filter:hover{
    opacity: 1;
    cursor: pointer;
  }

  .filter p{
    font-size: 0.8rem;
  }

  .filter.active{
    opacity: 1;
    border-bottom: 2px solid black;
  }

  .tax-info{
    display: none;
  }

  .tax-toggle{
    border:1px solid black;
    border-radius: 1rem;
    height: 3.5rem;
    padding:1rem;
    margin-left:5rem;
    display: flex;
    align-items: center;
  }
</style>

<!-- ================= FILTERS ================= -->
<div id="filters">

  <a href="/listings?category=All&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'All' ? 'active' : '' %>">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>

  <a href="/listings?category=rooms&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'rooms' ? 'active' : '' %>">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>

  <a href="/listings?category=iconic&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'iconic' ? 'active' : '' %>">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic cities</p>
  </a>

  <a href="/listings?category=mountains&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'mountains' ? 'active' : '' %>">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </a>

  <a href="/listings?category=castles&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'castles' ? 'active' : '' %>">
    <div><i class="fa-solid fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>

  <a href="/listings?category=arctic&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'arctic' ? 'active' : '' %>">
    <div><i class="fa-regular fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>

  <a href="/listings?category=pools&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'pools' ? 'active' : '' %>">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>

  <a href="/listings?category=camping&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'camping' ? 'active' : '' %>">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>

  <a href="/listings?category=farms&search=<%= search || '' %>" 
     class="filter <%= activeCategory === 'farms' ? 'active' : '' %>">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" id="switchCheckDefault">
      <label class="form-check-label">
        Display total after taxes
      </label>
    </div>
  </div>

</div>

<!-- ================= SEARCH TEXT ================= -->
<% if (search) { %>
  <h5 class="mt-3 text-muted">
    Showing results for "<b><%= search %></b>"
  </h5>
<% } %>

<!-- ================= NO RESULTS ================= -->
<% if (!alllistings || alllistings.length === 0) { %>
  <h4 class="text-center mt-5">No listings found 😔</h4>
<% } %>

<!-- ================= LISTINGS ================= -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

<% if (alllistings && alllistings.length > 0) { %>
  <% for (let listing of alllistings) { %>

    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">
        <img 
          src="<%= (listing.image && listing.image.url) 
            ? listing.image.url 
            : 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=800' %>"
          class="listing-img"
          style="height:20rem"
        >

        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b>
          </p>

          <p>
            &#8377;<%= listing.price.toLocaleString('en-IN') %>/night
            <i class="tax-info"> &nbsp;&nbsp; +18% GST</i>
          </p>
        </div>
      </div>
    </a>

  <% } %>
<% } %>

</div>

<!-- ================= TAX TOGGLE ================= -->
<script>
  const taxSwitch = document.getElementById("switchCheckDefault");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.getElementsByClassName("tax-info");

      for (let info of taxInfo) {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      }
    });
  }
</script>